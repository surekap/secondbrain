# ── Required ──────────────────────────────────────────────────────────────────
# All other configuration is managed through the UI at /agents.
DATABASE_URL=postgresql://user:password@localhost:5432/secondbrain

# ── Optional: seed API keys on first startup ──────────────────────────────────
# These can also be added later via the UI (Agents → Config / LLM Providers).
# Once stored in the database these env vars are no longer consulted.
#
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-proj-...
# LIMITLESS_API_KEY=sk-...
# NOTION_TOKEN=secret_...
# TODOIST_API_KEY=...
# TAVILY_API_KEY=tvly-...
# SERPAPI_API_KEY=...
# PEOPLEDATALABS_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
#
# Gmail (email agent — also configurable via UI):
# GMAIL_EMAIL_1=you@gmail.com
# GMAIL_APP_PASSWORD_1=xxxx xxxx xxxx xxxx

# ── WhatsApp connector ────────────────────────────────────────────────────────
# Required when running the WhatsApp bridge (npm run whatsapp).
# CLIENT_ID=my-phone          # unique identifier for this WhatsApp session
# WHATSAPP_PORT=3000          # HTTP port for the bridge admin UI (default: 3000)

# ── Server port (default: 4001) ───────────────────────────────────────────────
# UI_PORT=4001
